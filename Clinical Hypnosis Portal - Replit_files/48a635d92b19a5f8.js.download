    mutation CreateLimrunSimulator($input: CreateLimrunSimulatorInput!) {
  createLimrunSimulator(input: $input) {
    ... on LimrunSimulatorResult {
      instanceId
      webrtcUrl
      token
      state
      platform
    }
    ... on NotFoundError {
      message
    }
    ... on UnauthorizedError {
      message
    }
    ... on UserError {
      message
    }
    ... on ServiceUnavailable {
      message
    }
  }
}
    `,x=p.gql`
    query GetLimrunSimulator($replId: String!, $instanceId: String!, $platform: LimrunDevicePlatform!, $subreplId: String) {
  getRepl(id: $replId) {
    ... on Repl {
      id
      limrunSimulator(
        instanceId: $instanceId
        platform: $platform
        subreplId: $subreplId
      ) {
        ... on LimrunSimulatorResult {
          instanceId
          webrtcUrl
          token
          state
          platform
        }
        ... on NotFoundError {
          message
        }
        ... on UnauthorizedError {
          message
        }
        ... on ServiceUnavailable {
          message
        }
      }
    }
