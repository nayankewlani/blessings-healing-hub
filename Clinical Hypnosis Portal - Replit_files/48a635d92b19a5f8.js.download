    // ... handle error ...
}
`,ak=`const { ok, error } = await client.uploadFromFilename('file.json', srcFilename);
if (!ok) {
    // ... handle error ...
}
`,aE=`const { ok, error } = await client.uploadFromStream('file.json', stream);
if (!ok) {
