Brainstorming buddy",prompt:"Build a canvas based mind mapping tool that allows me to generate new ideas and have an AI integration to help come up with new ideas as well. Make the interface simple and inspired by popular canvas tools.",category:"AI Apps"},{images:["/public/images/lox/app-types/1c-recipe-generator.jpg"],title:"Recipe generator",prompt:"Create an AI powered tool where I can specify what I have in my fridge and the system recommends recipes of what to make. Make the app style like a retro restaurant menu, using elegant colors and fonts.",category:"AI Apps"},{images:["/public/images/lox/app-types/2a-landing-page.jpg"],title:"Landing page",prompt:"Create a landing page for a creative studio that works with clients across the world. Generate relevant images and videos as needed. Include a clear hero section. Make the website modern, creative, and inspiring.",category:"Websites"},{images:["/public/images/lox/app-types/2b-portfolio.jpg"],title:"Portfolio",prompt:"Create a personal portfolio website for a photographer which has an about me section and a gallery so I can can showcase my work. Make the website and photos black and white, with a very simple and minimal interface. ",category:"Websites"},{images:["/public/images/lox/app-types/2c-link-in-bio.jpg"],title:"Link-in-bio",prompt:"Make a link in bio app which presents all my social accounts in an easy, intuitive, and aesthetic interface. Use a random image for a profile picture placeholder for now.",category:"Websites"},{images:["/public/images/lox/app-types/3a-kpi-dashboard.jpg"],title:"KPI dashboard",prompt:"Create a data-driven dashboard that helps users monitor KPIs over time within their business. Use clear hierarchy, structured layouts, and realistic sample data and KPIs to start.",category:"Business Apps"},{images:["/public/images/lox/app-types/3b-roadmap.jpg"],title:"Roadmap planner",prompt:"Make a roadmap planning tool where product managers can create and visualize quarterly product roadmaps. Include draggable cards for initiatives, priority tags, and color coding by team. Design it with a professional timeline view and clean, modern UI.",category:"Business Apps"},{images:["/public/images/lox/app-types/3c-ecommerce.jpg"],title:"Ecommerce store",prompt:"Build a responsive, e-commerce experience for browsing and purchasing products. Include product listings, product detail views, and a checkout flow, with a modern, trustworthy design.",category:"Business Apps"},{images:["/public/images/lox/app-types/4a-habit-tracker.jpg"],title:"Habit tracker",prompt:"Make a personal habit tracker where users can set daily or weekly habits, log completions, and view streaks. Include progress bars and motivational messages. Use a clean, goal-focused layout.",category:"Personal Software"},{images:["/public/images/lox/app-types/4b-landmarks.jpg"],title:"Local landmarks",prompt:"Make an app that displays a map of local landmarks based on the current viewable area of the map. Use Wikipedia to get the landmarks.",category:"Personal Software"},{images:["/public/images/lox/app-types/4c-synth.jpg"],title:"Electronic synth",prompt:"Create an interactive synthesizer system visually inspired by tools like the Teenage Engineering OP-1. Focus on motion, tactile user feedback, and high quality sound.",category:"Personal Software"}];function f({index:e,imageUrls:s,title:l,onClick:r,badge:h,variant:f="loggedOut"}){let[g,b]=(0,a.useState)(!1),[v,j]=(0,a.useState)(!1),k=(0,a.useCallback)(()=>{r(),b(!0),j(!0),setTimeout(()=>{b(!1)},3e3),setTimeout(()=>{j(!1)},3500)},[r]);return(0,t.jsxs)(m.StaggerView,{options:{mode:"mount"},index:e,enabled:!0,gap:12,clsx:p.default.galleryItem,onClick:k,children:[(0,t.jsxs)(c.ShadesSurface,{elevate:"1x",background:!0,br:12,border:"subtle",clsx:p.default.galleryItemImage,children:[(0,t.jsx)(d.View,{clsx:p.default.mobileImageContainer,children:(0,t.jsx)(d.View,{clsx:p.default.mobileImage,children:(0,t.jsx)(u.default,{src:s[0],layout:"fill",objectFit:"cover",al